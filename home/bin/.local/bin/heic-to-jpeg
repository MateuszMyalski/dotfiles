#!/usr/bin/env bash
#!/bin/bash

# HEIC to JPEG Converter Script
# Converts HEIC images to JPEG format with optional cleanup
# Usage: ./heic_to_jpg.sh [-R] [directory]
#   -R: Recursive mode (process subdirectories)
#   directory: Target directory (default: current directory)

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check if heif-convert program exists
if ! command -v heif-convert &> /dev/null; then
    echo -e "${RED}Error: heif-convert program is not installed!${NC}"
    echo "Please install libheif tools package."
    exit 1
fi

# Parse command line arguments
RECURSIVE=false
TARGET_DIR="."

while [[ $# -gt 0 ]]; do
    case $1 in
        -R|-r)
            RECURSIVE=true
            shift
            ;;
        -h|--help)
            echo "Usage: $0 [-R] [directory]"
            echo "  -R          Recursive mode (process subdirectories)"
            echo "  directory   Target directory (default: current directory)"
            echo ""
            echo "Examples:"
            echo "  $0                    # Convert HEIC files in current directory"
            echo "  $0 /path/to/photos    # Convert HEIC files in specified directory"
            echo "  $0 -R /path/to/photos # Convert HEIC files recursively"
            exit 0
            ;;
        *)
            TARGET_DIR="$1"
            shift
            ;;
    esac
done

# Check if target directory exists
if [ ! -d "$TARGET_DIR" ]; then
    echo -e "${RED}Error: Directory '$TARGET_DIR' does not exist!${NC}"
    exit 1
fi

# Convert to absolute path
TARGET_DIR=$(cd "$TARGET_DIR" && pwd)

echo -e "${GREEN}Target directory: $TARGET_DIR${NC}"
if [ "$RECURSIVE" = true ]; then
    echo -e "${GREEN}Mode: Recursive${NC}"
else
    echo -e "${GREEN}Mode: Current directory only${NC}"
fi
echo ""

# Find HEIC files
actual_files=()

if [ "$RECURSIVE" = true ]; then
    # Find recursively
    while IFS= read -r -d '' file; do
        actual_files+=("$file")
    done < <(find "$TARGET_DIR" -type f \( -iname "*.heic" \) -print0)
else
    # Find only in target directory
    while IFS= read -r -d '' file; do
        actual_files+=("$file")
    done < <(find "$TARGET_DIR" -maxdepth 1 -type f \( -iname "*.heic" \) -print0)
fi

if [ ${#actual_files[@]} -eq 0 ]; then
    echo -e "${YELLOW}No HEIC files found.${NC}"
    exit 0
fi

# List HEIC files found
echo -e "${GREEN}Found ${#actual_files[@]} HEIC file(s):${NC}"
for f in "${actual_files[@]}"; do
    # Show relative path from target directory
    rel_path="${f#$TARGET_DIR/}"
    echo "  - $rel_path"
done
echo ""

# Convert HEIC files to JPEG
echo -e "${GREEN}Converting files...${NC}"
converted_count=0
failed_count=0

for f in "${actual_files[@]}"; do
    # Get the directory and base name
    dir=$(dirname "$f")
    base=$(basename "$f")
    name="${base%.*}"
    
    # Show relative path for output
    rel_path="${f#$TARGET_DIR/}"
    
    echo "Converting: $rel_path -> ${name}.jpg"
    
    if heif-convert -q 100 "$f" "$dir/${name}.jpg" 2>/dev/null; then
        echo -e "${GREEN}✓ Successfully converted${NC}"
        ((converted_count++))
    else
        echo -e "${RED}✗ Failed to convert${NC}"
        ((failed_count++))
    fi
done

echo ""
echo -e "${GREEN}Conversion complete!${NC}"
echo "Converted: $converted_count | Failed: $failed_count"
echo ""

# Ask if user wants to remove original HEIC files
if [ $converted_count -gt 0 ]; then
    echo -e "${YELLOW}Do you want to remove the original HEIC files? (y/N)${NC}"
    read -r response

    if [[ "$response" =~ ^[Yy]$ ]]; then
        echo ""
        echo -e "${YELLOW}Removing HEIC files:${NC}"
        removed_count=0
        for f in "${actual_files[@]}"; do
            # Only remove if conversion was successful (check if JPG exists)
            dir=$(dirname "$f")
            base=$(basename "$f")
            name="${base%.*}"
            
            if [ -f "$dir/${name}.jpg" ]; then
                rel_path="${f#$TARGET_DIR/}"
                echo "  Removing: $rel_path"
                rm -f "$f"
                ((removed_count++))
            fi
        done
        echo -e "${GREEN}✓ Removed $removed_count HEIC file(s).${NC}"
    else
        echo -e "${GREEN}HEIC files kept.${NC}"
    fi
fi

echo ""
echo "Done!"