#!/usr/bin/env bash

# Ignore upper and lowercase when tab completion
bind "set completion-ignore-case on"

# Change to named directory
shopt -s autocd
# Autocorrects cd misspellings
shopt -s cdspell
# Save multi-line commands in history as single line
shopt -s cmdhist
# Include '.' filenames that begins with . in results of filename expansion
shopt -s dotglob
# Expand aliases
shopt -s expand_aliases
# Checks term size when bash regains control
shopt -s checkwinsize

# Preserve history
export HISTCONTROL=ignoredups:erasedups  # no duplicate entries
export HISTSIZE=100000                   # big big history
export HISTFILESIZE=100000               # big big history
# Do not overwrite history
shopt -s histappend

export FZF_DEFAULT_OPTS=""

git_prompt() {
    local branch

    local GRAY="\033[90m"
    local YELLOW="\033[01;33m"
    local RESET="\033[0m"

    branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null) || return

    printf "${GRAY}⅄${RESET} ${YELLOW}%s" "$branch"

    if ! git diff --quiet --ignore-submodules 2>/dev/null ||
       ! git diff --cached --quiet --ignore-submodules 2>/dev/null; then
        printf "*"
    fi
    printf "${RESET} "
}

set_ps1() {
    local exit_code=$?

    # Colors
    local RESET="\[\e[0m\]"
    local WHITE="\[\e[37m\]"
    local RED="\[\e[31m\]"
    local GREEN="\[\e[32m\]"
    local CYAN="\[\e[01;36m\]"
    local GRAY="\[\e[90m\]"
    local YELLOW='\[\e[01;33m\]'

    # Connection indicator
    local indicator
    if [[ -n "$SSH_CONNECTION" ]]; then
        indicator="☁ "
    else
        indicator="● "
    fi

    # Indicator color
    local indicator_color
    case "$exit_code" in
        0)
            indicator_color="$GREEN"
            ;;
        *)
            indicator_color="$RED"
            ;;
    esac

    # Optional: white before any command has run
    if [[ -z "${__PROMPT_INITIALIZED:-}" ]]; then
        indicator_color="$WHITE"
        __PROMPT_INITIALIZED=1
    fi

    # Virtual environment indicator
    local venv_prefix=""
    if [[ -n "${VIRTUAL_ENV:-}" ]]; then
        venv_prefix="${GRAY}($(basename "$VIRTUAL_ENV"))${RESET} "
    fi

    PS1="${venv_prefix}${indicator_color}${indicator}${RESET} ${GRAY}\t${RESET} ${CYAN}\u${RESET}${GRAY}:${RESET}${YELLOW}\W${RESET} \$(git_prompt)${GRAY}%${RESET} "
}

export VIRTUAL_ENV_DISABLE_PROMPT=1
PROMPT_COMMAND=set_ps1

export PROMPT_COMMAND="$PROMPT_COMMAND"
